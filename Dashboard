class SymptomsChatScreen extends StatefulWidget {
  final UserHealthData healthData;
  final bool initialLang;

  const SymptomsChatScreen({
    super.key,
    required this.healthData,
    required this.initialLang,
  });

  @override
  State<SymptomsChatScreen> createState() => _SymptomsChatScreenState();
}

class _SymptomsChatScreenState extends State<SymptomsChatScreen>
    with SingleTickerProviderStateMixin {
  late bool _isArabic;

  final Set<String> _selected = {};
  String _activeCat = 'all';
  final _searchCtrl = TextEditingController();
  String _searchQuery = '';

  final _chatCtrl = TextEditingController();
  final _chatScroll = ScrollController();
  final List<ChatMessage> _messages = [];
  bool _botTyping = false;

  late AnimationController _anim;
  late Animation<double> _fade;

  @override
  void initState() {
    super.initState();
    _isArabic = widget.initialLang;
    _messages.add(
      ChatMessage(
        text: _isArabic
            ? 'مرحباً! أخبرني بأي أعراض إضافية بكلماتك الخاصة وسأساعدك. 👋'
            : 'Hi! Tell me about any additional symptoms in your own words. 👋',
        isUser: false,
      ),
    );
    _anim = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 450),
    );
    _fade = CurvedAnimation(parent: _anim, curve: Curves.easeOut);
    _anim.forward();
  }

  @override
  void dispose() {
    _searchCtrl.dispose();
    _chatCtrl.dispose();
    _chatScroll.dispose();
    _anim.dispose();
    super.dispose();
  }

  String _s(String ar, String en) => t(ar, en, _isArabic);
  void _toggleLang() => setState(() => _isArabic = !_isArabic);

  List<Map<String, String>> get _filtered => _kSymptoms.where((s) {
    final catOk = _activeCat == 'all' || s['cat'] == _activeCat;
    final q = _searchQuery.toLowerCase();
    final searchOk =
        q.isEmpty || s['ar']!.contains(q) || s['en']!.toLowerCase().contains(q);
    return catOk && searchOk;
  }).toList();

  void _sendMessage() {
    final text = _chatCtrl.text.trim();
    if (text.isEmpty) return;

    setState(() {
      _messages.add(ChatMessage(text: text, isUser: true));
      _chatCtrl.clear();
      _botTyping = true;
    });

    _scrollBottom();

    Future.delayed(const Duration(milliseconds: 1800), () {
      if (!mounted) return;
      setState(() {
        _botTyping = false;
        _messages.add(
          ChatMessage(
            text: _isArabic
                ? 'شكراً! تم تسجيل ما ذكرته وسيؤخذ بعين الاعتبار في خطتك الصحية.'
                : 'Thank you! Your input has been noted and will be reflected in your health plan.',
            isUser: false,
          ),
        );
      });
      _scrollBottom();
    });
  }

  void _scrollBottom() {
    WidgetsBinding.instance.addPostFrameCallback((_) {
      if (_chatScroll.hasClients) {
        _chatScroll.animateTo(
          _chatScroll.position.maxScrollExtent,
          duration: const Duration(milliseconds: 280),
          curve: Curves.easeOut,
        );
      }
    });
  }

  Future<void> _goNext() async {
    if (_selected.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(
            _s('اختر عرضاً واحداً على الأقل', 'Select at least one symptom'),
          ),
          backgroundColor: AppColors.skyBlue,
          behavior: SnackBarBehavior.floating,
          shape: RoundedRectangleBorder(
            borderRadius: BorderRadius.circular(12),
          ),
        ),
      );
      return;
    }

    widget.healthData
      ..selectedSymptoms = _selected.toList()
      ..chatMessages = List.from(_messages);

    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (_) => const Center(child: CircularProgressIndicator()),
    );

    try {
      final result = await ApiService.sendTriage(
        age: widget.healthData.age ?? 0,
        weight: (widget.healthData.weightKg ?? 0).toDouble(),
        gender: widget.healthData.gender ?? '',
        bloodSugar: double.tryParse(widget.healthData.bloodSugar ?? '') ?? 0.0,
        cholesterol: double.tryParse(widget.healthData.cholesterol ?? '') ?? 0.0,
        hemoglobin: double.tryParse(widget.healthData.hemoglobin ?? '') ?? 0.0,
        bloodPressure: widget.healthData.bloodPressure ?? '',
        selectedSymptoms: _selected.toList(),
        chatMessages: _messages
            .where((m) => m.isUser)
            .map((m) => m.text)
            .toList(),
      );

      if (!mounted) return;
      Navigator.pop(context);

      Navigator.push(
        context,
        MaterialPageRoute(
          builder: (_) => HealthPlanScreen(
            healthData: widget.healthData,
            initialLang: _isArabic,
            result: result,
          ),
        ),
      );
    } catch (e) {
      if (!mounted) return;
      Navigator.pop(context);

      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(
            _s('فشل الاتصال بالخادم', 'Failed to connect to backend'),
          ),
          backgroundColor: Colors.red,
          behavior: SnackBarBehavior.floating,
        ),
      );
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: AppColors.background,
      body: FadeTransition(
        opacity: _fade,
        child: Column(
          children: [
            ScreenHeader(
              title: _s('الأعراض والتشخيص', 'Symptoms & Diagnosis'),
              subtitle: _s(
                'اختر أعراضك أو تحدث مع المساعد',
                'Select symptoms or chat with the assistant',
              ),
              icon: Icons.medical_services_outlined,
              isArabic: _isArabic,
              onToggleLang: _toggleLang,
            ),
            Padding(
              padding: const EdgeInsets.fromLTRB(22, 14, 22, 0),
              child: StepProgress(
                currentStep: 2,
                totalSteps: 3,
                isArabic: _isArabic,
              ),
            ),
            const SizedBox(height: 12),
            Expanded(
              child: DefaultTabController(
                length: 2,
                child: Column(
                  children: [
                    Padding(
                      padding: const EdgeInsets.symmetric(horizontal: 18),
                      child: Container(
                        height: 42,
                        decoration: BoxDecoration(
                          color: AppColors.grayLight,
                          borderRadius: BorderRadius.circular(12),
                        ),
                        child: TabBar(
                          indicator: BoxDecoration(
                            color: AppColors.skyBlue,
                            borderRadius: BorderRadius.circular(10),
                          ),
                          indicatorSize: TabBarIndicatorSize.tab,
                          labelColor: Colors.white,
                          unselectedLabelColor: AppColors.textSecondary,
                          labelStyle: const TextStyle(
                            fontSize: 13,
                            fontWeight: FontWeight.w600,
                          ),
                          dividerColor: Colors.transparent,
                          tabs: [
                            Tab(text: _s('الأعراض', 'Symptoms')),
                            Tab(text: _s('المحادثة', 'Chat')),
                          ],
                        ),
                      ),
                    ),
                    const SizedBox(height: 10),
                    Expanded(
                      child: TabBarView(
                        children: [
                          _SymptomsTab(
                            symptoms: _filtered,
                            selected: _selected,
                            activeCat: _activeCat,
                            searchCtrl: _searchCtrl,
                            isArabic: _isArabic,
                            onCatChanged: (c) => setState(() => _activeCat = c),
                            onSearchChanged: (q) => setState(() => _searchQuery = q),
                            onToggle: (en) => setState(() {
                              if (_selected.contains(en)) {
                                _selected.remove(en);
                              } else {
                                _selected.add(en);
                              }
                            }),
                          ),
                          _ChatTab(
                            messages: _messages,
                            chatCtrl: _chatCtrl,
                            scrollCtrl: _chatScroll,
                            botTyping: _botTyping,
                            isArabic: _isArabic,
                            onSend: _sendMessage,
                          ),
                        ],
                      ),
                    ),
                  ],
                ),
              ),
            ),
            Container(
              padding: const EdgeInsets.fromLTRB(18, 10, 18, 26),
              decoration: BoxDecoration(
