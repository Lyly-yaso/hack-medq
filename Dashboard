  Widget _sectionTitle(String text) {
    return Text(
      text,
      style: const TextStyle(
        color: AppPalette.subtext,
        fontSize: 13,
        fontWeight: FontWeight.w700,
      ),
    );
  }

  Widget _recommendationCard({
    required List<String> items,
    required Color dotColor,
  }) {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: AppPalette.card,
        borderRadius: BorderRadius.circular(18),
        border: Border.all(color: AppPalette.border),
      ),
      child: Column(
        children: items.map((item) {
          return Padding(
            padding: const EdgeInsets.only(bottom: 12),
            child: Row(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Container(
                  width: 8,
                  height: 8,
                  margin: const EdgeInsets.only(top: 7),
                  decoration: BoxDecoration(
                    color: dotColor,
                    shape: BoxShape.circle,
                  ),
                ),
                const SizedBox(width: 10),
                Expanded(
                  child: Text(
                    item,
                    style: const TextStyle(color: AppPalette.text, height: 1.6),
                  ),
                ),
              ],
            ),
          );
        }).toList(),
      ),
    );
  }

  Map<String, dynamic> getRiskStyle(String risk) {
    switch (risk.toLowerCase()) {
      case 'high':
        return {
          'labelAr': 'خطر عالٍ',
          'labelEn': 'High risk',
          'color': const Color(0xFFEF4444),
          'bg': const Color(0xFF2A1416),
          'border': const Color(0xFF7F1D1D),
          'accent': const Color(0xFFFCA5A5),
          'icon': '▲',
          'adviceAr': 'يوصى بمتابعة الحالة طبياً في أقرب وقت.',
          'adviceEn': 'Medical follow-up is recommended as soon as possible.',
        };
      case 'low':
        return {
          'labelAr': 'خطر منخفض',
          'labelEn': 'Low risk',
          'color': const Color(0xFF22C55E),
          'bg': const Color(0xFF11251A),
          'border': const Color(0xFF14532D),
          'accent': const Color(0xFF86EFAC),
          'icon': '●',
          'adviceAr': 'يمكن الاكتفاء بالمتابعة المنزلية والراحة غالباً.',
          'adviceEn':
              'Home monitoring and rest may be sufficient in most cases.',
        };
      default:
        return {
          'labelAr': 'خطر متوسط',
          'labelEn': 'Medium risk',
          'color': const Color(0xFFF59E0B),
          'bg': const Color(0xFF2E2411),
          'border': const Color(0xFF8A5A12),
          'accent': const Color(0xFFFCD34D),
          'icon': '◆',
          'adviceAr': 'من الأفضل متابعة الأعراض واستشارة مختص إذا لزم الأمر.',
          'adviceEn':
              'It is better to monitor symptoms and consult a specialist if needed.',
        };
    }
  }
