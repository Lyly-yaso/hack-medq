/// Simple data model to carry user info across screens.
/// No state management library needed — just plain Dart classes.

class UserHealthData {
  // --- Page 1: Basic Info ---
  String gender; // 'male' | 'female'
  int? age;
  double? weightKg;

  // Blood report fields
  String? bloodSugar;
  String? cholesterol;
  String? hemoglobin;
  String? bloodPressure;

  // --- Page 2: Symptoms & Chat ---
  List<String> selectedSymptoms;
  List<ChatMessage> chatMessages;

  UserHealthData({
    this.gender = 'male',
    this.age,
    this.weightKg,
    this.bloodSugar,
    this.cholesterol,
    this.hemoglobin,
    this.bloodPressure,
    List<String>? selectedSymptoms,
    List<ChatMessage>? chatMessages,
  })  : selectedSymptoms = selectedSymptoms ?? [],
        chatMessages = chatMessages ?? [];
}

class ChatMessage {
  final String text;
  final bool isUser;
  final DateTime timestamp;

  ChatMessage({
    required this.text,
    required this.isUser,
    DateTime? timestamp,
  }) : timestamp = timestamp ?? DateTime.now();
}
